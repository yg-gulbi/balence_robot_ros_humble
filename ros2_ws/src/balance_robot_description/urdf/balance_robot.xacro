<?xml version="1.0"?>
<robot name="balance_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ========================================================
       balance_robot.xacro
       Wheeled Inverted Pendulum (2-wheel balance robot)
       Control: libgazebo_ros_diff_drive (velocity control)
       ======================================================== -->

  <!-- ===================== Properties ====================== -->
  <xacro:property name="body_mass"       value="1.0"/>
  <xacro:property name="body_width"      value="0.10"/>
  <xacro:property name="body_depth"      value="0.08"/>
  <xacro:property name="body_height"     value="0.28"/>
  <xacro:property name="wheel_mass"      value="0.1"/>
  <xacro:property name="wheel_radius"    value="0.05"/>
  <xacro:property name="wheel_width"     value="0.02"/>
  <xacro:property name="body_com_height" value="0.15"/>
  <xacro:property name="wheel_sep"       value="0.14"/>

  <!-- ===================== Inertia Macros ================== -->
  <xacro:macro name="box_inertia" params="m w h d">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${(1/12)*m*(h*h + d*d)}"
        iyy="${(1/12)*m*(w*w + d*d)}"
        izz="${(1/12)*m*(w*w + h*h)}"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <xacro:macro name="cylinder_inertia" params="m r l">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${(1/12)*m*(3*r*r + l*l)}"
        iyy="${(1/2)*m*r*r}"
        izz="${(1/12)*m*(3*r*r + l*l)}"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <!-- ===================== Links ============================ -->
  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${body_com_height}" rpy="0 0 0"/>
      <geometry>
        <box size="${body_width} ${body_depth} ${body_height}"/>
      </geometry>
      <material name="blue">
        <color rgba="0.2 0.4 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 ${body_com_height}" rpy="0 0 0"/>
      <geometry>
        <box size="${body_width} ${body_depth} ${body_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${body_mass}" w="${body_width}" h="${body_height}" d="${body_depth}"/>
  </link>

  <link name="imu_link">
    <visual>
      <geometry><box size="0.01 0.01 0.01"/></geometry>
      <material name="red"><color rgba="1 0 0 1"/></material>
    </visual>
  </link>

  <link name="left_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" l="${wheel_width}"/>
  </link>

  <link name="right_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="${wheel_mass}" r="${wheel_radius}" l="${wheel_width}"/>
  </link>

  <!-- ===================== Joints ========================== -->
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="imu_link"/>
    <origin xyz="0 0 ${body_com_height}" rpy="0 0 0"/>
  </joint>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="left_wheel_link"/>
    <origin xyz="0 ${wheel_sep/2} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.01" friction="0.1"/>
  </joint>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="right_wheel_link"/>
    <origin xyz="0 ${-wheel_sep/2} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.01" friction="0.1"/>
  </joint>

  <!-- ===================== Gazebo Plugins ================== -->

  <!-- IMU sensor -->
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>200</update_rate>
      <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
        <ros>
          <remapping>~/out:=/imu/data</remapping>
        </ros>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
        <frame_name>imu_link</frame_name>
      </plugin>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.002</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.002</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.002</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.017</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.017</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.017</stddev></noise></z>
        </linear_acceleration>
      </imu>
    </sensor>
  </gazebo>

  <!-- Differential drive controller
       Subscribes to /cmd_vel_wheels → drives left/right wheel joints
       Publishes  /odom              → odometry for velocity feedback   -->
  <gazebo>
    <plugin name="differential_drive_controller" filename="libgazebo_ros_diff_drive.so">
      <ros>
        <remapping>cmd_vel:=cmd_vel_wheels</remapping>
        <remapping>odom:=odom</remapping>
      </ros>
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>${wheel_sep}</wheel_separation>
      <wheel_diameter>${2*wheel_radius}</wheel_diameter>
      <max_wheel_torque>20</max_wheel_torque>
      <max_wheel_acceleration>10</max_wheel_acceleration>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
      <publish_wheel_tf>false</publish_wheel_tf>
      <odometry_frame>odom</odometry_frame>
      <robot_base_frame>base_footprint</robot_base_frame>
    </plugin>
  </gazebo>

  <!-- Wheel friction -->
  <gazebo reference="left_wheel_link">
    <mu1>1.0</mu1><mu2>1.0</mu2>
    <kp>1e6</kp><kd>100</kd>
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="right_wheel_link">
    <mu1>1.0</mu1><mu2>1.0</mu2>
    <kp>1e6</kp><kd>100</kd>
    <material>Gazebo/DarkGrey</material>
  </gazebo>
  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
  </gazebo>

</robot>
