<?xml version="1.0"?>
<robot name="balance_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ========================================================
       balance_robot.xacro
       Wheeled Inverted Pendulum (2-wheel balance robot)

       Coordinate convention (REP-103):
         x: forward,  y: left,  z: up
       ======================================================== -->

  <!-- ===================== Properties ====================== -->
  <!-- Body dimensions -->
  <xacro:property name="body_mass"   value="1.0"/>
  <xacro:property name="body_width"  value="0.10"/>   <!-- x (depth) -->
  <xacro:property name="body_depth"  value="0.08"/>   <!-- y -->
  <xacro:property name="body_height" value="0.28"/>   <!-- z -->

  <!-- Wheel dimensions -->
  <xacro:property name="wheel_mass"   value="0.1"/>
  <xacro:property name="wheel_radius" value="0.05"/>
  <xacro:property name="wheel_width"  value="0.02"/>

  <!-- Body CoM height above wheel axis -->
  <xacro:property name="body_com_height" value="0.15"/>

  <!-- Wheel separation (center-to-center along Y) -->
  <xacro:property name="wheel_sep" value="0.14"/>

  <!-- ===================== Inertia Macros ================== -->
  <!-- Solid box inertia -->
  <xacro:macro name="box_inertia" params="m w h d">
    <inertial>
      <mass value="${m}"/>
      <inertia
        ixx="${(1/12)*m*(h*h + d*d)}"
        iyy="${(1/12)*m*(w*w + d*d)}"
        izz="${(1/12)*m*(w*w + h*h)}"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <!-- Solid cylinder inertia (axis = Y, i.e., wheel spin axis) -->
  <xacro:macro name="cylinder_inertia" params="m r l">
    <inertial>
      <mass value="${m}"/>
      <!-- ixx/izz: axis perpendicular to cylinder axis -->
      <inertia
        ixx="${(1/12)*m*(3*r*r + l*l)}"
        iyy="${(1/2)*m*r*r}"
        izz="${(1/12)*m*(3*r*r + l*l)}"
        ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </xacro:macro>

  <!-- ===================== Links ============================ -->

  <!-- World (fixed reference, used only for floating joint workaround) -->
  <!-- base_footprint: virtual link at ground level -->
  <link name="base_footprint"/>

  <!-- Base link = chassis body -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${body_com_height}" rpy="0 0 0"/>
      <geometry>
        <box size="${body_width} ${body_depth} ${body_height}"/>
      </geometry>
      <material name="blue">
        <color rgba="0.2 0.4 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 ${body_com_height}" rpy="0 0 0"/>
      <geometry>
        <box size="${body_width} ${body_depth} ${body_height}"/>
      </geometry>
    </collision>
    <xacro:box_inertia m="${body_mass}"
                       w="${body_width}"
                       h="${body_height}"
                       d="${body_depth}"/>
  </link>

  <!-- IMU link (center of body, same as base_link CoM) -->
  <link name="imu_link">
    <visual>
      <geometry><box size="0.01 0.01 0.01"/></geometry>
      <material name="red"><color rgba="1 0 0 1"/></material>
    </visual>
  </link>

  <!-- Left wheel -->
  <link name="left_wheel_link">
    <visual>
      <!-- cylinder default axis is Z; rotate 90° around X to align with Y -->
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="${wheel_mass}"
                            r="${wheel_radius}"
                            l="${wheel_width}"/>
  </link>

  <!-- Right wheel -->
  <link name="right_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.2 0.2 0.2 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="${pi/2} 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_width}"/>
      </geometry>
    </collision>
    <xacro:cylinder_inertia m="${wheel_mass}"
                            r="${wheel_radius}"
                            l="${wheel_width}"/>
  </link>

  <!-- ===================== Joints ========================== -->

  <!-- base_footprint → base_link (planar joint; robot sits at wheel axis height) -->
  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin xyz="0 0 ${wheel_radius}" rpy="0 0 0"/>
  </joint>

  <!-- base_link → imu_link (fixed, at body CoM) -->
  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="imu_link"/>
    <origin xyz="0 0 ${body_com_height}" rpy="0 0 0"/>
  </joint>

  <!-- base_link → left_wheel (continuous = free rotation around Y) -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="left_wheel_link"/>
    <origin xyz="0 ${wheel_sep/2} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.01" friction="0.1"/>
    <limit effort="10.0" velocity="10.0"/>
  </joint>

  <!-- base_link → right_wheel (continuous) -->
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child  link="right_wheel_link"/>
    <origin xyz="0 ${-wheel_sep/2} 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="0.01" friction="0.1"/>
    <limit effort="10.0" velocity="10.0"/>
  </joint>

  <!-- ===================== ros2_control ==================== -->
  <!-- Hardware interface: Gazebo sim -->
  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gazebo_ros2_control/GazeboSystem</plugin>
    </hardware>
    <joint name="left_wheel_joint">
      <command_interface name="effort">
        <param name="min">-10</param>
        <param name="max"> 10</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="right_wheel_joint">
      <command_interface name="effort">
        <param name="min">-10</param>
        <param name="max"> 10</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

  <!-- ===================== Gazebo Plugins ================== -->
  <!-- IMU sensor plugin -->
  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>200</update_rate>
      <plugin name="imu_plugin" filename="libgazebo_ros_imu_sensor.so">
        <ros>
          <remapping>~/out:=/imu/data</remapping>
        </ros>
        <initial_orientation_as_reference>false</initial_orientation_as_reference>
        <frame_name>imu_link</frame_name>
      </plugin>
      <imu>
        <angular_velocity>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.002</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.002</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.002</stddev></noise></z>
        </angular_velocity>
        <linear_acceleration>
          <x><noise type="gaussian"><mean>0</mean><stddev>0.017</stddev></noise></x>
          <y><noise type="gaussian"><mean>0</mean><stddev>0.017</stddev></noise></y>
          <z><noise type="gaussian"><mean>0</mean><stddev>0.017</stddev></noise></z>
        </linear_acceleration>
      </imu>
    </sensor>
  </gazebo>

  <!-- gazebo_ros2_control plugin -->
  <gazebo>
    <plugin name="gazebo_ros2_control" filename="libgazebo_ros2_control.so">
      <robot_sim_type>gazebo_ros2_control/GazeboSystem</robot_sim_type>
      <parameters>$(find balance_robot_gazebo)/config/ros2_control.yaml</parameters>
    </plugin>
  </gazebo>

  <!-- Wheel friction (Gazebo material) -->
  <gazebo reference="left_wheel_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1e6</kp>
    <kd>100</kd>
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <gazebo reference="right_wheel_link">
    <mu1>1.0</mu1>
    <mu2>1.0</mu2>
    <kp>1e6</kp>
    <kd>100</kd>
    <material>Gazebo/DarkGrey</material>
  </gazebo>

  <gazebo reference="base_link">
    <material>Gazebo/Blue</material>
  </gazebo>

</robot>
